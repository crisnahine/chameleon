# Copy this file to .env and fill in absolute paths to your test repos.
# .env is gitignored so each developer can point tests at their own repos.
#
# All vars are optional. When unset, tests that need a real repo skip
# gracefully.

# Path to a TypeScript repository for real-Claude-Code acceptance tests.
# Must contain tsconfig.json and/or package.json so chameleon detects it
# as TypeScript.
CHAMELEON_TEST_TS_REPO=

# Path to a Ruby repository for real-Claude-Code acceptance tests.
# Must contain Gemfile and/or *.gemspec so chameleon detects it as Ruby.
# For Rails-aware guidance, also include config/application.rb.
CHAMELEON_TEST_RUBY_REPO=

# Path to a Python repository for real-Claude-Code acceptance tests.
# Detected as Python via a project marker (pyproject.toml, setup.py,
# setup.cfg, requirements.txt, manage.py, Pipfile, or tox.ini) or any .py
# file. For framework-aware guidance, use a Django, DRF, Flask, or FastAPI repo.
CHAMELEON_TEST_PYTHON_REPO=
