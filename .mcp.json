{
  "mcpServers": {
    "chameleon-mcp": {
      "command": "uvx",
      "args": [
        "--refresh-package",
        "chameleon-mcp",
        "--from",
        "${CLAUDE_PLUGIN_ROOT}/mcp",
        "chameleon-mcp"
      ],
      "env": {
        "CLAUDE_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  }
}
