# chameleon profile auto-merge
#
# Copy this file to your repo as `.gitattributes` (or merge into existing one)
# to enable automatic profile merge resolution via chameleon-mcp.
#
# This prevents painful JSON merge conflicts when two developers run
# /chameleon-refresh on parallel branches.

.chameleon/profile.json     merge=chameleon
.chameleon/archetypes.json  merge=chameleon
.chameleon/rules.json       merge=chameleon
.chameleon/canonicals.json  merge=chameleon
.chameleon/conventions.json merge=chameleon

# Generated index artifacts (exports_index.json, reverse_index.json,
# function_catalog.json) are intentionally NOT routed to the merge driver:
# they have no structural merge, and the correct resolution for a conflict
# on them is to accept either side and run /chameleon-refresh, which
# regenerates all three from the merged repo state.

# To register the merge driver, run once in your repo (or globally with --global):
#
#   git config merge.chameleon.name "chameleon profile merge"
#   git config merge.chameleon.driver "/path/to/chameleon/scripts/chameleon-merge-driver.sh %O %A %B %P"
#
# Replace /path/to/chameleon with your installed plugin dir, e.g.
#   ~/.claude/plugins/cache/chameleon/chameleon/<version>
# (The old `chameleon-mcp merge_profiles ...` form does not work — that console
#  script only launches the stdio MCP server; the shell driver above is the real
#  merge driver.)
#
# Without registration, git falls back to its default conflict-marker behavior.
