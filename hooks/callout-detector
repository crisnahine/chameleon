#!/usr/bin/env bash
# UserPromptSubmit hook for chameleon plugin.
#
# Detects user frustration phrases and surfaces actionable next steps.
# Delegates to chameleon_mcp.hook_helper.callout_detector which:
#   1. Reads payload from stdin (user_prompt)
#   2. Matches against _FRUSTRATION_PATTERNS
#   3. On match, emits a hint about /chameleon-disable / /chameleon-pause-15m /
#      /chameleon-teach as additionalContext
#
# Fail-open: any failure → emit empty JSON. Never block the user prompt.
#
# See ARCHITECTURE.md "Hook stack" UserPromptSubmit section + Round 5 UX
# Researcher recommendation #6 (discoverable disable on frustration).

set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${0%/*}/..}"
MCP_DIR="${PLUGIN_ROOT}/mcp"

if [ -d "${MCP_DIR}/.venv" ]; then
    PYTHON="${MCP_DIR}/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
    PYTHON="$(command -v python)"
else
    printf '{}\n'
    exit 0
fi

# 2-second hard timeout — frustration hint is not worth blocking on.
PYTHONPATH="${MCP_DIR}${PYTHONPATH:+:${PYTHONPATH}}" \
    timeout 2 "${PYTHON}" -m chameleon_mcp.hook_helper callout-detector \
    || printf '{}\n'
