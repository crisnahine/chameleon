#!/usr/bin/env bash
# PostToolUse Bash hook for chameleon plugin.
#
# HMAC-signed exec log for debugging + cookbook scoring (advisory).
# Delegates to chameleon_mcp.hook_helper.posttool_recorder which:
#   1. Reads payload from stdin (tool_input.command, tool_response.returnCode,
#      session_id, CLAUDE_CWD)
#   2. Computes repo_id = sha256(resolved CLAUDE_CWD)
#   3. Appends an HMAC-signed log line to
#      ${TMPDIR:-/tmp}/.chameleon_exec_log/<repo_id>/<session_id>.jsonl
#
# Fail-open: any failure → emit empty JSON. Never block Bash from completing.
#
# See ARCHITECTURE.md "Hook stack" PostToolUse Bash + "Security mitigations"
# #5 (per-repo HMAC log directory).

set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${0%/*}/..}"
MCP_DIR="${PLUGIN_ROOT}/mcp"

if [ -d "${MCP_DIR}/.venv" ]; then
    PYTHON="${MCP_DIR}/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
    PYTHON="$(command -v python)"
else
    printf '{}\n'
    exit 0
fi

# BUG-NEW-010 (v0.5.7): rotating error log so silent failures are diagnosable.
LOG_DIR="${HOME}/.local/share/chameleon"
mkdir -p "${LOG_DIR}" 2>/dev/null || true
LOG_FILE="${LOG_DIR}/.hook_errors.log"

# 2-second hard timeout — log writes should be near-instant.
PYTHONPATH="${MCP_DIR}" \
    timeout 2 "${PYTHON}" -m chameleon_mcp.hook_helper posttool-recorder \
    2>>"${LOG_FILE}" \
    || { echo "[$(date -u +%FT%TZ)] posttool-recorder failed (python=${PYTHON})" >>"${LOG_FILE}"; printf '{}\n'; }
