#!/usr/bin/env bash
# PostToolUse Edit/Write/NotebookEdit hook for chameleon plugin.
#
# Archetype conformance lint: reads the written file, lints against its
# archetype, and feeds violations back via additionalContext so the model
# can self-correct.
#
# Default ON. Set CHAMELEON_VERIFY=0 to disable.
# Fail-open: any failure -> emit empty JSON. Never block tool completion.

set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${0%/*}/..}"
MCP_DIR="${PLUGIN_ROOT}/mcp"

if [ -d "${MCP_DIR}/.venv" ]; then
    PYTHON="${MCP_DIR}/.venv/bin/python"
elif command -v python3.13 >/dev/null 2>&1; then
    PYTHON="$(command -v python3.13)"
elif command -v python3.12 >/dev/null 2>&1; then
    PYTHON="$(command -v python3.12)"
elif command -v python3.11 >/dev/null 2>&1; then
    PYTHON="$(command -v python3.11)"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
    PYTHON="$(command -v python)"
else
    printf '{}\n'
    exit 0
fi

if [ -n "${CHAMELEON_HOOK_ERROR_LOG:-}" ]; then
    LOG_FILE="${CHAMELEON_HOOK_ERROR_LOG}"
    LOG_DIR="$(dirname "${LOG_FILE}")"
else
    LOG_DIR="${HOME}/.local/share/chameleon"
    LOG_FILE="${LOG_DIR}/.hook_errors.log"
fi
mkdir -p "${LOG_DIR}" 2>/dev/null || true
"${PYTHON}" -m chameleon_mcp.log_rotation "${LOG_FILE}" 2>/dev/null || true

# 3-second hard timeout (cold-start import chain takes ~2s without daemon)
PYTHONPATH="${MCP_DIR}" \
    timeout 3 "${PYTHON}" -m chameleon_mcp.hook_helper posttool-verify \
    2>>"${LOG_FILE}" \
    || { echo "[$(date -u +%FT%TZ)] posttool-verify failed (python=${PYTHON})" >>"${LOG_FILE}"; printf '{}\n'; }
