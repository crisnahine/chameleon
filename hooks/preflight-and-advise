#!/usr/bin/env bash
# PreToolUse Edit/Write/NotebookEdit hook for chameleon plugin.
#
# Phase 4 implementation: delegates to chameleon_mcp.hook_helper which:
#   1. Reads tool_input.file_path from stdin JSON
#   2. Calls chameleon_mcp.tools.get_pattern_context(file_path)
#   3. Emits archetype + canonical excerpt as additionalContext
#
# Fail-open contract per ARCHITECTURE.md "Hook stack": if anything fails,
# emit empty JSON and let the edit proceed.
#
# See ARCHITECTURE.md "Hook stack" PreToolUse + "Performance characteristics"
# (the daemon model that replaces this subprocess-per-call form).

set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${0%/*}/..}"
MCP_DIR="${PLUGIN_ROOT}/mcp"

if [ -d "${MCP_DIR}/.venv" ]; then
    PYTHON="${MCP_DIR}/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
    PYTHON="$(command -v python)"
else
    printf '{}\n'
    exit 0
fi

# BUG-NEW-010 (v0.5.7): when the helper fails silently (typical when
# system python3 lacks chameleon_mcp deps), keep a rotating error log so
# users can diagnose why no advisory is firing. The log lives outside
# the plugin tree to survive plugin upgrades.
LOG_DIR="${HOME}/.local/share/chameleon"
mkdir -p "${LOG_DIR}" 2>/dev/null || true
LOG_FILE="${LOG_DIR}/.hook_errors.log"

# 2-second hard timeout (Round 5 Performance Engineer recommendation)
PYTHONPATH="${MCP_DIR}${PYTHONPATH:+:${PYTHONPATH}}" \
    timeout 2 "${PYTHON}" -m chameleon_mcp.hook_helper preflight-and-advise \
    2>>"${LOG_FILE}" \
    || { echo "[$(date -u +%FT%TZ)] preflight-and-advise failed (python=${PYTHON})" >>"${LOG_FILE}"; printf '{}\n'; }
