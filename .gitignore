# Local profile cache (never commit per-user state)
.chameleon/drift.db
.chameleon/.skip
.chameleon/.tmp/
.chameleon/.lock

# Local env (test repo paths, etc.)
.env

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# Node
node_modules/
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# Build artifacts
dist/
build/

# Test coverage
.coverage
htmlcov/
coverage.xml
tests/calibration/corpus.json

# Per-app dogfood reports for internal-only repos. SUMMARY.md anonymizes
# their entries; the per-app dumps stay local.
docs/dogfood/**/REPORT-ef-*.md
docs/dogfood/**/log-*.txt

# Dogfood runner result artifacts (timestamped runs stay local)
tests/dogfood/results/dogfood_*.json
tests/dogfood/results/dogfood_*.md

# Local Claude Code state (worktrees, session caches, agent transcripts)
.claude/

# Journey harness run output (per-run ephemeral dirs)
tests/journey/results/

# Effectiveness eval run output (per-run ephemeral dirs)
tests/effectiveness/results/
# Pytest cache for harness library tests
tests/journey/harness/tests/__pycache__/
tests/journey/harness/tests/.pytest_cache/
docs/superpowers/
.in_use/
